# Shopify
SHOPIFY_WEBHOOK_SECRET=whsec_example_secret
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_STORE_URL=rectella.myshopify.com

# VPN (Cisco AnyConnect — required to reach RIL-APP01 / RIL-DB01)
VPN_HOST=rectella-internationa-wireless-w-tqngtmvdtj.dynamic-m.com
VPN_USERNAME=your_vpn_username
VPN_PASSWORD=your_vpn_password

# SYSPRO
# Port 30000 is documented default but currently closed on RIL-APP01.
# Confirm correct port with Reece Taylor / NCS before first test.
# Open candidates: 30110, 30180, 30181, 30190.
SYSPRO_ENET_URL=http://192.168.3.150:30000/saborest
SYSPRO_OPERATOR=your_operator
SYSPRO_PASSWORD=your_password
SYSPRO_COMPANY_ID=your_company_id

# Database
DATABASE_URL=postgres://rectella:rectella@localhost:5432/rectella?sslmode=disable

# Scheduling
STOCK_SYNC_INTERVAL=15m
BATCH_INTERVAL=5m

# Logging
LOG_LEVEL=debug
